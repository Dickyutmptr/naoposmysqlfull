// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// User (Admin/Cashier)
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("cashier") // 'admin', 'cashier'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  reports   Report[]
}

// Member (Loyalty) - Gets 5% Discount
model Member {
  id          Int      @id @default(autoincrement())
  name        String
  phoneNumber String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

// Product Categories
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique // 'Coffee', 'Non-Coffee', 'Makanan', 'Showcase'
  products  Product[]
}

// Products
model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  hpp         Float       @default(0)
  description String?
  image       String?
  isActive    Boolean     @default(true)
  isDeleted   Boolean     @default(false)
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  recipes     Recipe[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Inventory / Ingredients
model Ingredient {
  id                Int      @id @default(autoincrement())
  sku               String?  // SKU manually inputted
  name              String   @unique
  stock             Float    // Current stock
  unit              String   // 'gr', 'ml', 'pcs'
  category          String   @default("minuman") // 'minuman', 'makanan'
  minStockThreshold Float    @default(0) // Alert when below this
  lastAlertDate     DateTime? // To track daily alerts
  recipes           Recipe[]
  updatedAt         DateTime @updatedAt
}

// Recipe (Jembatan Product <-> Ingredient)
model Recipe {
  id           Int        @id @default(autoincrement())
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  amount       Float      // Amount needed per product
}

// Orders
model Order {
  id             Int         @id @default(autoincrement())
  orderId        String      @unique // Format: NB260210-001
  queueNumber    Int         // 1-999 reset daily
  customerName   String
  tableNumber    String?
  
  // Member linkage
  memberId       Int?
  member         Member?     @relation(fields: [memberId], references: [id])
  
  // Financials
  totalAmount    Float       // Subtotal before tax/discount
  taxAmount      Float       // 12% PPN (PB1)
  discountAmount Float       // 5% if member, etc.
  serviceCharge  Float       @default(0) // 3% Service Charge
  finalAmount    Float       // Total to pay
  
  paymentMethod  String      // 'cash', 'qris', 'edc'
  status         String      @default("pending") // 'pending', 'completed', 'cancelled'
  
  // Kitchen/Bar Status
  kitchenStatus  String      @default("pending") // 'pending', 'done'
  barStatus      String      @default("pending")
  
  // Who processed it
  userId         Int
  user           User        @relation(fields: [userId], references: [id])
  
  // Cancellation Details
  cancelReason   String?
  cancelNote     String?
  
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// Order Items
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  price     Float   // Snapshot price
  note      String? // 'Less Sugar', etc.
}

// Simple Report Log (Optional, for events)
model Report {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  category    String   // 'Kitchen', 'Bar', 'Kasir'
  description String
  imageUrl    String? // Store as URL/Text for now
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}
